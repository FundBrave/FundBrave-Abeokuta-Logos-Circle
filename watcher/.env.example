# ─── Base / EVM ──────────────────────────────────────────────────────────────

# Base mainnet or Base Sepolia RPC endpoint
BASE_RPC_URL=https://sepolia.base.org

# Private key of the watcher "float wallet" on Base (0x-prefixed)
# This wallet must hold USDC to pay out donations, and ETH for gas.
WATCHER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# AbeokutaCampaign contract address on Base
CAMPAIGN_ADDRESS=0xYOUR_CAMPAIGN_ADDRESS

# USDC contract on Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# USDC contract on Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ─── Bitcoin ─────────────────────────────────────────────────────────────────

# Bitcoin address to watch for incoming deposits
BTC_ADDRESS=bc1qYOUR_BITCOIN_ADDRESS

# Blockstream API (default is fine for mainnet; use /testnet for testnet)
# BLOCKSTREAM_API_URL=https://blockstream.info/api
# BLOCKSTREAM_API_URL=https://blockstream.info/testnet/api

# ─── Solana ───────────────────────────────────────────────────────────────────

# Solana wallet address to watch
SOL_ADDRESS=YourSolanaAddressHere

# Solana RPC (default: mainnet-beta public node)
# SOL_RPC_URL=https://api.mainnet-beta.solana.com
# SOL_RPC_URL=https://api.devnet.solana.com

# USDC mint on Solana mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# USDC mint on Solana devnet:  Gh9ZwEmdLJ8DscKNTkTqPbNwLNNBjuSzaG9Vp2KGtKJr
SOL_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Polling intervals ────────────────────────────────────────────────────────

# How often to poll Bitcoin blockchain (milliseconds)
BTC_POLL_INTERVAL_MS=30000

# How often to poll Solana blockchain (milliseconds)
SOL_POLL_INTERVAL_MS=10000

# ─── Price feed ───────────────────────────────────────────────────────────────

# CoinGecko price cache TTL (milliseconds). Default: 60s
PRICE_CACHE_TTL_MS=60000

# ─── Donation settings ───────────────────────────────────────────────────────

# Minimum USD value of a deposit to trigger an on-chain donation (avoids dust)
MIN_DONATION_USD=1.0

# ─── State ────────────────────────────────────────────────────────────────────

# Path to the processed txs JSON file (relative to watcher root)
# STORE_FILE=./processed_txs.json
