{
  "name": "@abeokuta-mini/watcher",
  "version": "1.0.0",
  "description": "Centralized watcher: detects BTC/SOL deposits and credits them to the campaign contract",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec \"ts-node src/index.ts\"",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "echo 'No automated tests yet — see SECURITY_AUDIT_REPORT.md informational section' && exit 0"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "axios": "^1.7.9",
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
