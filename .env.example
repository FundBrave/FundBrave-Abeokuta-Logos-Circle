# ─── Smart Contract Addresses ──────────────────────────────────────────────
# Populated after running: npm run deploy:testnet

NEXT_PUBLIC_CAMPAIGN_ADDRESS=0x
NEXT_PUBLIC_STAKING_ADDRESS=0x
NEXT_PUBLIC_TREASURY_ADDRESS=0x         # Gnosis Safe multisig address
NEXT_PUBLIC_BRIDGE_ADDRESS=0xb3C210cB2075e72B10f00c41e30120480017a136  # FundBrave Bridge (Base Sepolia)

# ─── Cross-chain Bridge Addresses (FundBraveBridge on each source chain) ─────
NEXT_PUBLIC_BRIDGE_BASE_ADDRESS=0x
NEXT_PUBLIC_BRIDGE_ETHEREUM_ADDRESS=0x
NEXT_PUBLIC_BRIDGE_POLYGON_ADDRESS=0x
NEXT_PUBLIC_BRIDGE_ARBITRUM_ADDRESS=0x
NEXT_PUBLIC_BRIDGE_OPTIMISM_ADDRESS=0x

# ─── Non-EVM Manual Donation Addresses ──────────────────────────────────────
# Treasury wallets monitored by campaign organisers.
# Donations credited to campaign within 24–48 hours after verification.
NEXT_PUBLIC_BTC_ADDRESS=                # Bitcoin (BTC) — native Bitcoin network
NEXT_PUBLIC_SOL_ADDRESS=                # Solana (SOL / USDC-SPL) — Solana network

# ─── Token Addresses (Base Sepolia defaults) ────────────────────────────────
NEXT_PUBLIC_USDC_ADDRESS=0xf269f54304f8DB2dB613341CC7E189B02BEf98dE
NEXT_PUBLIC_DAI_ADDRESS=0xD5F45AE6088fE7DadA621C8A70F94abE3F46f7Bf
NEXT_PUBLIC_WETH_ADDRESS=0x8140C9fE21D9639FD69E9eF345Be39d767eE7FE2

# ─── Wallet Connect ─────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_from_cloud_walletconnect_com

# ─── Multisig Signers (for dashboard display) ───────────────────────────────
NEXT_PUBLIC_SIGNER_1=0x         # Abeokuta Circle Lead 1
NEXT_PUBLIC_SIGNER_2=0x         # Abeokuta Circle Lead 2
NEXT_PUBLIC_SIGNER_3=0x         # Logos Network representative
NEXT_PUBLIC_REQUIRED_SIGS=2     # N-of-M (2-of-3)

# ─── Contracts deployment env vars ──────────────────────────────────────────
PRIVATE_KEY=0x                  # Deployer private key (testnet only, never commit)
ALCHEMY_API_KEY=
BASESCAN_API_KEY=
TREASURY_MULTISIG=0x            # Gnosis Safe address (must exist before deploy)
PLATFORM_WALLET=0x              # FundBrave platform fee recipient
